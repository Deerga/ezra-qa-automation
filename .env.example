# Ezra Staging Credentials
# Copy this file to .env and fill in with real values
# WARNING: .env is gitignored — never commit it

# Platform URLs
BASE_URL=https://myezra-staging.ezra.com

# Test Account Credentials
TEST_USER_EMAIL=your-test-email@example.com
TEST_USER_PASSWORD=your-test-password

# User Details for Booking Flow
TEST_USER_DOB=01-01-1985
TEST_USER_SEX=Male

# Second member ID for cross-member data isolation test (optional)
# Set this to a second staging account ID to enable the cross-member security test
TEST_MEMBER_B_ID=
